TEST_CASE("Sha256StepRecorder::customSha256", "[transform]") {

    SECTION("empty") {
    
        Sha256StepRecorder record;
        std::string empty(" ");
        std::vector<uint8_t>  input = stringToBytes(empty);
        std::vector<uint8_t> res =  record.customSha256(input);

        std::vector<uint8_t> expected = hexToBytes(
            "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
        );

        REQUIRE(res.size() == 32);
        REQUIRE(compareVectors( expected, res ));
       
    }

}